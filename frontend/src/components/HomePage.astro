---
import { getCollection } from "astro:content";
import PostPage from "./PostPage.astro";

const posts = await getCollection("posts");
const latestPost = posts[posts.length - 1];
const olderPosts = posts.slice(0, -1).reverse();

const { Content } = await latestPost.render();
---

<div class="max-w-275 mx-auto p-8 text-white">
  <!-- Latest Post - Full Content -->
  <section>
    <article>
      <div class="max-w-162.5 mb-6">
        <h1 class="text-3xl font-bold mb-2">{latestPost.data.title}</h1>
        {
          latestPost.data.artist && (
            <p class="text-neutral-400 my-1">
              <strong>Artist:</strong> {latestPost.data.artist}
            </p>
          )
        }
        {
          latestPost.data.album && (
            <p class="text-neutral-400 my-1">
              <strong>Album:</strong> {latestPost.data.album}
            </p>
          )
        }
      </div>

      <div class="max-w-[650px] mt-4 mb-10 text-neutral-300 leading-relaxed">
        <content></content>
      </div>

      {
        latestPost.data.lyrics && latestPost.data.lyrics.length > 0 && (
          <div class="border-t border-neutral-700 pt-8">
            <PostPage lyrics={latestPost.data.lyrics} />
          </div>
        )
      }
    </article>
  </section>

  <!-- Older Posts -->
  {
    olderPosts.length > 0 && (
      <section class="border-t border-neutral-700 mt-12 pt-8">
        <h2 class="text-2xl font-semibold mb-4">Earlier Posts</h2>
        <div class="grid grid-cols-1 gap-4">
          {olderPosts.map((post) => (
            <a
              href={`/posts/${post.slug}`}
              class="block p-5 border border-neutral-700 rounded-lg no-underline text-inherit transition-colors duration-200 hover:border-neutral-500"
            >
              <h3 class="text-lg mb-1">{post.data.title}</h3>
              {post.data.artist && (
                <p class="text-neutral-400 text-sm my-0.5">
                  {post.data.artist}
                </p>
              )}
              {post.data.album && (
                <p class="text-neutral-400 text-sm my-0.5">{post.data.album}</p>
              )}
            </a>
          ))}
        </div>
      </section>
    )
  }
</div>
